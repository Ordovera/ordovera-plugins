{
  "name": "cc-mcp-audit",
  "version": "1.0.0",
  "description": "Governance posture analysis for MCP servers. Extracts tool inventories, classifies sensitivity, detects auth/logging/gate patterns, and surfaces named accountability gaps. Does not detect code-level vulnerabilities -- pair with SAST and dependency scanning for deployment decisions.",
  "type": "module",
  "bin": {
    "cc-mcp-audit": "./dist/cli.js"
  },
  "files": [
    "dist",
    "prompts",
    "!dist/**/*.test.*"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ordovera/ordovera-plugins.git",
    "directory": "packages/cc-mcp-audit"
  },
  "homepage": "https://github.com/ordovera/ordovera-plugins/tree/main/packages/cc-mcp-audit",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "lint": "eslint src/"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "governance",
    "governance-audit",
    "tool-analysis",
    "ai-governance"
  ],
  "author": {
    "name": "Brian Fending",
    "email": "brian@ordovera.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  }
}
